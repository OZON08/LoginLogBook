# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=replace-with-influx-token
INFLUX_ORG=loginlogbook
INFLUX_BUCKET=logins

# ── API tokens ────────────────────────────────────────────────────────────────
# Admin token — used for /clients and /reasons management endpoints
ADMIN_TOKEN=replace-with-admin-token

# Client token — accepted from login overlay clients (one token for all hosts,
# or use the /clients API to manage per-host tokens after first start)
CLIENT_TOKEN=replace-with-client-token

# ── Persistence (paths inside the container, mounted via api-data volume) ─────
REASONS_FILE=/data/reasons.json
LOGO_DIR=/data/logo
CLIENTS_FILE=/data/clients.json

# ── InfluxDB first-start setup ────────────────────────────────────────────────
# Remove DOCKER_INFLUXDB_INIT_MODE after the first successful start
DOCKER_INFLUXDB_INIT_MODE=setup
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=replace-with-strong-password
DOCKER_INFLUXDB_INIT_ORG=loginlogbook
DOCKER_INFLUXDB_INIT_BUCKET=logins
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=replace-with-influx-token

# ── TLS / Domain ──────────────────────────────────────────────────────────────
# Domain under which LoginLogBook is reachable. Written as the CN of the
# self-signed bootstrap cert and used as the certbot certificate domain.
TLS_DOMAIN=loginlogbook.example.com

# On first start, the `certs-init` container auto-generates a self-signed
# certificate into nginx/certs/ if none exists. For a browser-trusted cert on a
# public domain, enable certbot (see README "HTTPS & Zertifikate"):
#   docker compose --profile certbot up -d
#   ./scripts/init-letsencrypt.sh
#
# E-mail for Let's Encrypt registration and expiry warnings (certbot profile).
CERTBOT_EMAIL=admin@example.com

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password
