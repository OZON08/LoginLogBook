      ],
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"logins\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"login_events\")\n  |> filter(fn: (r) => r.host =~ /^${host:regex}$/)\n  |> filter(fn: (r) => r.os_user =~ /^${os_user:regex}$/)\n  |> keep(columns: [\"_time\", \"host\", \"os_user\", \"event_type\", \"reason\"])\n  |> group()\n  |> sort(columns: [\"_time\"], desc: true)"
        }
      ]
    }
