  "panels": [
    {
      "id": 9,
      "title": "@@grafana.sicher.byhour@@",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 14,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "influxdb",
        "uid": "loginlogbook-influxdb"
      },
      "description": "@@grafana.sicher.byhour.desc@@",
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "valueMode": "color",
        "showUnfilled": true,
        "reduceOptions": {
          "values": true,
          "calcs": [],
          "fields": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "query": "import \"date\"\nfrom(bucket: \"logins\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"login_events\" and r.event_type == \"login\")\n  |> filter(fn: (r) => r.host =~ /^${host:regex}$/)\n  |> filter(fn: (r) => r.os_user =~ /^${os_user:regex}$/)\n  |> map(fn: (r) => ({hour: date.hour(t: r._time), val: 1}))\n  |> group(columns: [\"hour\"])\n  |> count(column: \"val\")\n  |> group()\n  |> sort(columns: [\"hour\"])\n  |> map(fn: (r) => ({Stunde: string(v: r.hour), Anmeldungen: r.val}))\n  |> keep(columns: [\"Stunde\", \"Anmeldungen\"])"
        }
      ]
    },
    {
      "id": 10,
      "title": "@@grafana.sicher.offhours@@",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 14,
        "y": 0
      },
      "datasource": {
        "type": "influxdb",
        "uid": "loginlogbook-influxdb"
      },
      "description": "@@grafana.sicher.offhours.desc@@",
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "query": "import \"date\"\nfrom(bucket: \"logins\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"login_events\" and r.event_type == \"login\")\n  |> filter(fn: (r) => r.host =~ /^${host:regex}$/)\n  |> filter(fn: (r) => r.os_user =~ /^${os_user:regex}$/)\n  |> map(fn: (r) => ({r with hour: date.hour(t: r._time)}))\n  |> filter(fn: (r) => r.hour < 7 or r.hour >= 17)\n  |> count()\n  |> group()\n  |> sum()"
        }
      ]
    },
    {
      "id": 11,
      "title": "@@grafana.sicher.noreason@@",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 5,
        "x": 19,
        "y": 0
      },
      "datasource": {
        "type": "influxdb",
        "uid": "loginlogbook-influxdb"
      },
      "description": "@@grafana.sicher.noreason.desc@@",
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "sum"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"logins\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"login_events\" and r.event_type == \"login\")\n  |> filter(fn: (r) => not exists r.reason)\n  |> filter(fn: (r) => r.host =~ /^${host:regex}$/)\n  |> filter(fn: (r) => r.os_user =~ /^${os_user:regex}$/)\n  |> count()\n  |> group()\n  |> sum()"
        }
      ]
    },
