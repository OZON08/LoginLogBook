            "lineWidth": 1,
            "spanNulls": false
          },
          "color": {
            "mode": "palette-classic"
          },
          "displayName": "${__field.labels.event_type}"
        }
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"logins\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"login_events\")\n  |> filter(fn: (r) => r.host =~ /^${host:regex}$/)\n  |> filter(fn: (r) => r.os_user =~ /^${os_user:regex}$/)\n  |> group(columns: [\"event_type\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: count, createEmpty: false)"
        }
      ]
